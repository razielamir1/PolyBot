# ── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Polymarket ────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=30          # How often to fetch prices (seconds)
PRICE_CHANGE_THRESHOLD_PCT=10.0   # Alert threshold (%)
ROLLING_WINDOW_SECONDS=300        # Rolling window size (seconds, default=5min)
MIN_VOLUME_USD=100000             # Minimum event volume to track ($)
TOP_N_MARKETS=50                  # Max number of events to monitor
FETCH_LIMIT=100                   # Max events to pull from Gamma API
FETCH_WORKERS=50                  # Concurrent HTTP workers for price fetch

# ── Alert ─────────────────────────────────────────────────────────────
ALERT_COOLDOWN_SECONDS=300        # Min seconds between repeat alerts per token

# ── Dashboard ─────────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=5588               # Local port (Railway uses PORT env var instead)
